{
  "name": "widget",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:settings": "rsbuild build -c rsbuild.config.settings.mjs",
    "build:view": "rsbuild build -c rsbuild.config.view.mjs",
    "build:settings:watch": "npm run build:settings -- --watch",
    "build:view:watch": "npm run build:view -- --watch",
    "build:all": "npm run build:settings && npm run build:view",
    "check": "biome check --write",
    "dev": "rsbuild dev --open",
    "format": "biome format --write",
    "preview": "rsbuild preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@rsbuild/core": "^1.4.3",
    "@rsbuild/plugin-react": "^1.3.3"
  }
}