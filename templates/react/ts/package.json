{
  "name": "widget",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:control": "rsbuild build -c rsbuild.config.control.ts",
    "build:view": "rsbuild build -c rsbuild.config.view.ts",
    "build:control:watch": "npm run build:control -- --watch",
    "build:view:watch": "npm run build:view -- --watch",
    "build:all": "npm run build:control && npm run build:view",
    "check": "biome check --write",
    "dev": "rsbuild dev --open",
    "format": "biome format --write",
    "preview": "rsbuild preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@rsbuild/core": "^1.4.3",
    "@rsbuild/plugin-react": "^1.3.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3"
  }
}